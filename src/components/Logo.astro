---
// Placeholder PSL/i wordmark (indigo) until final brand assets exist.
interface Props {
  class?: string;
}
const { class: klass = '' } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${klass}`}>
  <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
    <rect width="26" height="26" rx="7" fill="url(#psli-grad)" />
    <path
      d="M13 5l1.7 4.7L19.5 11l-4.8 1.7L13 17l-1.7-4.3L6.5 11l4.8-1.3L13 5z"
      fill="#fff"
    />
    <defs>
      <linearGradient id="psli-grad" x1="0" y1="0" x2="26" y2="26" gradientUnits="userSpaceOnUse">
        <stop stop-color="#6A5CF6" />
        <stop offset="1" stop-color="#8B7CF8" />
      </linearGradient>
    </defs>
  </svg>
  <span class="text-[19px] font-bold tracking-[-0.02em] text-ink">PSL/i</span>
</span>
