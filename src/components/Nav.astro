---
import { nav, cta } from '../data/site';
import { href } from '../lib/url';
import Logo from './Logo.astro';
import Button from './Button.astro';
---

<header
  class="sticky top-0 z-50 border-b border-border/70 bg-bg/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-5 py-3.5 sm:px-8"
    aria-label="Primary"
  >
    <a href={href('/')} class="shrink-0" aria-label="PSL/i home">
      <Logo />
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-7 lg:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={href(item.href)}
              class="text-[15px] font-medium text-ink-2 transition-colors hover:text-primary"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={href(cta.login.href)}
        class="text-[15px] font-medium text-ink-2 transition-colors hover:text-primary"
      >
        {cta.login.label}
      </a>
      <Button href={cta.primary.href} variant="primary" class="!px-4 !py-2.5">
        {cta.primary.label}
      </Button>
    </div>

    <!-- Mobile menu: pure CSS via <details>, no JS -->
    <details class="group relative lg:hidden">
      <summary
        class="flex cursor-pointer list-none items-center rounded-[var(--radius-btn)] border border-border bg-surface p-2 [&::-webkit-details-marker]:hidden"
        aria-label="Toggle menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </summary>
      <div
        class="absolute right-0 mt-2 w-60 rounded-[var(--radius-card)] border border-border bg-surface p-2 shadow-[var(--shadow-lift)]"
      >
        <ul class="flex flex-col">
          {
            nav.map((item) => (
              <li>
                <a
                  href={href(item.href)}
                  class="block rounded-lg px-3 py-2.5 text-[15px] font-medium text-ink-2 hover:bg-bg hover:text-primary"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-2 border-t border-border pt-2">
          <a
            href={href(cta.login.href)}
            class="block rounded-lg px-3 py-2.5 text-[15px] font-medium text-ink-2 hover:bg-bg"
          >
            {cta.login.label}
          </a>
          <Button href={cta.primary.href} variant="primary" class="mt-1 w-full">
            {cta.primary.label}
          </Button>
        </div>
      </div>
    </details>
  </nav>
</header>
