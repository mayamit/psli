---
// V1-honest "Navigator approval moment" surface. Static, illustrative.
import { navigatorApproval as data } from '../data/navigator';
import { accent as accentMap, type Accent } from '../lib/accents';

const icons: Record<string, string> = {
  mail: 'M4 6h16v12H4z M4 7l8 6 8-6',
  calendar: 'M4 5h16v15H4z M4 9h16 M8 3v4 M16 3v4',
  shield: 'M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z',
};
---

<figure
  class="overflow-hidden rounded-[var(--radius-card)] border border-border bg-surface shadow-[var(--shadow-lift)]"
  aria-label="Illustration of PSL/i's approval surface"
>
  <!-- header -->
  <div class="flex items-center gap-3 border-b border-border px-5 py-3">
    <span class="flex h-7 w-7 items-center justify-center rounded-lg text-white" style="background:var(--grad)">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" />
      </svg>
    </span>
    <div class="leading-tight">
      <p class="text-sm font-semibold text-ink">{data.title}</p>
      <p class="text-xs text-muted">{data.subhead}</p>
    </div>
  </div>

  <div class="p-4">
    <!-- auto-applied strip -->
    <div class="mb-3 flex items-start gap-2 rounded-[10px] border border-c-green/30 bg-c-green/10 px-3 py-2.5 text-xs text-ink-2">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-c-green" aria-hidden="true">
        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>{data.auto}</span>
    </div>

    <!-- queue -->
    <div class="flex flex-col gap-3">
      {
        data.items.map((item) => {
          const a = accentMap[item.accent as Accent];
          return (
            <div class={`rounded-[var(--radius-card)] border bg-surface ${item.open ? 'border-primary/30 shadow-[var(--shadow-card)]' : 'border-border'}`}>
              <div class="flex items-center gap-3 px-4 py-3">
                <span class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] ${a.softBg} ${a.text}`}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    {item.icon && icons[item.icon].split(' M').map((seg, i) => (
                      <path d={(i === 0 ? seg : 'M' + seg)} stroke="currentColor" stroke-width="2" fill="none" />
                    ))}
                  </svg>
                </span>
                <div class="min-w-0 flex-1">
                  <p class="truncate text-sm font-semibold text-ink">{item.title}</p>
                  <p class="truncate text-xs text-muted">{item.meta}</p>
                </div>
                <span class={`hidden rounded-full px-2.5 py-1 text-[10.5px] font-semibold sm:inline ${a.softBg} ${a.text}`}>
                  {item.badge}
                </span>
              </div>

              {item.open && item.preview && (
                <div class="border-t border-border bg-bg/60 px-4 pb-4 pt-3">
                  <div class="mb-3 flex gap-2 rounded-[10px] border border-border bg-surface px-3 py-2 text-xs text-ink-2">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
                      <path d="M12 8v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    <span><b class="text-ink">Why PSL/i prepared this:</b> {item.why}</span>
                  </div>
                  <div class="overflow-hidden rounded-[10px] border border-border">
                    <div class="border-b border-border bg-surface px-3 py-2 text-xs text-muted">
                      <b class="text-ink">To:</b> {item.preview.to} · <b class="text-ink">Subject:</b> {item.preview.subject}
                    </div>
                    <div class="space-y-2 bg-surface px-3 py-3">
                      {item.preview.lines.map((line) => (
                        <p class="whitespace-pre-line text-[13px] leading-relaxed text-ink">{line}</p>
                      ))}
                    </div>
                  </div>
                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center gap-1.5 rounded-[10px] bg-primary px-3.5 py-2 text-[13px] font-semibold text-white">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 12h15M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      Approve & send
                    </span>
                    <span class="rounded-[10px] border border-border px-3.5 py-2 text-[13px] font-semibold text-ink">Edit draft</span>
                    <span class="px-2 py-2 text-[13px] font-semibold text-c-rose-700">Discard</span>
                  </div>
                </div>
              )}
            </div>
          );
        })
      }
    </div>

    <!-- footer -->
    <p class="mt-4 flex items-center justify-center gap-2 text-center text-xs text-muted">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-primary" aria-hidden="true">
        <path d="M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z" stroke="currentColor" stroke-width="2" />
      </svg>
      {data.footer}
    </p>
  </div>
</figure>
<p class="mt-3 text-center text-xs text-muted">Illustrative V1 surface. Outbound actions and anything unusual are gated for your review.</p>
