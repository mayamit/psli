---
import SectionShell from '../SectionShell.astro';
import SectionHeading from '../SectionHeading.astro';
import Button from '../Button.astro';
import { pricing } from '../../data/home';
---

<SectionShell>
  <SectionHeading eyebrow="Pricing" title={pricing.headline} subhead={pricing.subhead} center />

  <div class="mx-auto mt-12 max-w-lg">
    <div class="overflow-hidden rounded-[var(--radius-card)] border border-border bg-surface shadow-[var(--shadow-lift)]">
      <div class="px-8 py-8 text-center" style="background:var(--grad)">
        <div class="flex items-baseline justify-center gap-1 text-white">
          <span class="text-5xl font-bold tracking-tight">{pricing.price}</span>
          <span class="text-lg font-medium opacity-90">{pricing.cadence}</span>
        </div>
        <p class="mt-2 text-sm text-white/85">Cloud or Home Server — same price.</p>
      </div>
      <div class="px-8 py-7">
        <ul class="space-y-3.5">
          {
            pricing.includes.map((item) => (
              <li class="flex items-start gap-3 text-[15px] text-ink">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
        <Button href={pricing.cta.href} variant="primary" class="mt-7 w-full">{pricing.cta.label}</Button>
        <p class="mt-4 text-center text-sm italic text-muted">{pricing.note}</p>
      </div>
    </div>
  </div>
</SectionShell>
