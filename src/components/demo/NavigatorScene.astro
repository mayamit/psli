---
// Scene 2 — Navigator: intent → propose → approve → act (human-gated).
// Matches the visual language of NavigatorApproval.astro, made interactive:
// prompt chips + fuzzy-matched free-text reveal a proposal card; the user
// approves, edits, or declines; approval appends an audit line. All scripted.
import { scene2, scene2ExtraResponses, scene2ExtraPrompts } from '../../data/demo';
import { emailProvenance } from '../../lib/demo';
import { accent as accentMap, type Accent } from '../../lib/accents';
import ProvenanceChip from './ProvenanceChip.astro';

// Merge the expansion pack in (no schema change, no renames): extra intents
// become both fuzzy-match targets and chips.
const responseMap: Record<string, any> = { ...scene2.responses, ...scene2ExtraResponses };
const responses = Object.entries(responseMap);
const suggestedPrompts = [...scene2.suggestedPrompts, ...scene2ExtraPrompts];
// Chips are the suggested prompts, mapped to their response key by intent.
const keyForIntent = (intent: string) => responses.find(([, r]) => r.intent === intent)?.[0];
const chips = suggestedPrompts
  .map((label) => ({ label, key: keyForIntent(label) }))
  .filter((c): c is { label: string; key: string } => Boolean(c.key));

// Icon + accent per proposal type (kept out of the data file).
const typeMeta: Record<string, { accent: Accent; label: string; paths: string[] }> = {
  email: { accent: 'blue', label: 'Email', paths: ['M4 6h16v12H4z', 'M4 7l8 6 8-6'] },
  reminder: { accent: 'violet', label: 'Reminder', paths: ['M4 5h16v15H4z', 'M4 9h16', 'M8 3v4', 'M16 3v4'] },
  payment: { accent: 'amber', label: 'Payment', paths: ['M12 3v18', 'M8 8h5a2.5 2.5 0 010 5H9a2.5 2.5 0 000 5h6'] },
  document: { accent: 'violet', label: 'Document', paths: ['M6 3h8l4 4v14H6z', 'M14 3v4h4'] },
};
---

<section aria-labelledby="scene2-title" data-nav-scene>
  <!-- Scene intro -->
  <div class="mb-6">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      {scene2.eyebrow}
    </span>
    <h2 id="scene2-title" class="mt-3 text-2xl font-semibold text-ink sm:text-[28px]">{scene2.title}</h2>
  </div>

  <!-- Prompt box: chips + fuzzy-matched free text -->
  <div class="rounded-[var(--radius-card)] border border-border bg-surface p-4 shadow-[var(--shadow-card)]">
    <p class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-muted">Try an intent</p>
    <div class="flex flex-wrap gap-2">
      {
        chips.map((chip) => (
          <button
            type="button"
            data-nav-chip={chip.key}
            class="rounded-full border border-border bg-bg px-3.5 py-1.5 text-[13px] font-medium text-ink-2 transition-colors hover:border-primary hover:text-primary focus-visible:outline-2"
          >
            {chip.label}
          </button>
        ))
      }
    </div>
    <form data-nav-form class="mt-3 flex gap-2" novalidate>
      <input
        type="text"
        data-nav-input
        autocomplete="off"
        placeholder="…or type your own — e.g. “reply to Glenn about the model”"
        aria-label="Tell Navigator what you want"
        class="min-w-0 flex-1 rounded-[var(--radius-btn)] border border-border bg-bg px-3.5 py-2.5 text-[14px] text-ink placeholder:text-muted focus-visible:outline-2"
      />
      <button type="submit" class="shrink-0 rounded-[var(--radius-btn)] bg-primary px-4 py-2.5 text-[14px] font-semibold text-white transition-colors hover:bg-primary-700">
        Ask Navigator
      </button>
    </form>
    <p data-nav-fallback hidden class="mt-2.5 flex items-start gap-2 rounded-[10px] border border-c-amber/30 bg-c-amber/10 px-3 py-2 text-[13px] text-ink-2">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-c-amber-700" aria-hidden="true">
        <path d="M12 9v4m0 4h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L14.7 3.9a2 2 0 00-3.4 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>I don’t have that in this demo — try one of the intents above.</span>
    </p>
  </div>

  <!-- Results -->
  <div class="mt-6">
    <p data-nav-empty class="rounded-[var(--radius-card)] border border-dashed border-border bg-surface/60 px-6 py-14 text-center text-sm text-muted">
      Pick an intent above. Navigator will propose exactly what it plans to do — and wait for you.
    </p>

    {
      responses.map(([key, r]: [string, any]) => (
        <div data-nav-response={key} data-nav-match={r.matches.join('|')} hidden>
          <div class="mx-auto max-w-xl">
            <figure
              data-nav-card
              class="overflow-hidden rounded-[var(--radius-card)] border border-border bg-surface shadow-[var(--shadow-lift)] transition-all duration-300"
              aria-label="Navigator proposal, awaiting your approval"
            >
              <!-- card header -->
              <div class="flex items-center gap-3 border-b border-border px-5 py-3.5">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg text-white" style="background:var(--grad)">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" />
                  </svg>
                </span>
                <div class="min-w-0 leading-tight">
                  <p class="text-sm font-semibold text-ink">Navigator wants to do {r.proposals.length} {r.proposals.length === 1 ? 'thing' : 'things'}</p>
                  <p class="truncate text-xs text-muted">{r.intent}</p>
                </div>
                <span data-nav-status class="ml-auto hidden shrink-0 rounded-full border border-border bg-bg px-2.5 py-1 text-[10.5px] font-semibold text-muted sm:inline">Awaiting approval</span>
              </div>

              <!-- proposals -->
              <div class="flex flex-col gap-3 p-4">
                {r.proposals.map((p: any) => {
                  const tm = typeMeta[p.type];
                  const a = accentMap[tm.accent];
                  return (
                    <div class="rounded-[var(--radius-card)] border border-border bg-bg/50">
                      <div class="flex items-center gap-2.5 px-4 py-2.5">
                        <span class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-lg ${a.softBg} ${a.text}`}>
                          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            {tm.paths.map((d) => (
                              <path d={d} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            ))}
                          </svg>
                        </span>
                        <p class="text-[13px] font-semibold text-ink">{p.title}</p>
                        <span class={`ml-auto rounded-full px-2 py-0.5 text-[10px] font-semibold ${a.softBg} ${a.text}`}>{tm.label}</span>
                      </div>

                      {p.type === 'email' && (
                        <div class="border-t border-border px-4 py-3">
                          <p class="mb-2 text-[11.5px] text-muted"><b class="text-ink">To:</b> {p.to} · <b class="text-ink">Subject:</b> {p.subject}</p>
                          <p data-nav-draft class="whitespace-pre-line rounded-[10px] border border-border bg-surface px-3 py-2.5 text-[13px] leading-relaxed text-ink">{p.draft}</p>
                          <textarea data-nav-editor hidden class="mt-0 w-full rounded-[10px] border border-primary/40 bg-surface px-3 py-2.5 text-[13px] leading-relaxed text-ink focus-visible:outline-2" rows="5">{p.draft}</textarea>
                          {p.sourceEmailId && <div class="mt-2"><ProvenanceChip label={emailProvenance(p.sourceEmailId)} accent="blue" quiet /></div>}
                        </div>
                      )}

                      {p.type === 'reminder' && (
                        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 border-t border-border px-4 py-3 text-[13px] text-ink-2">
                          <span class="text-ink">{p.detail}</span>
                          <span class="rounded-full bg-primary-50 px-2 py-0.5 text-[11.5px] font-medium text-primary-700">{p.when}</span>
                        </div>
                      )}

                      {p.type === 'document' && (
                        <div class="border-t border-border px-4 py-3">
                          <p class="text-[13px] text-ink">{p.detail}</p>
                          {p.sourceEmailId && <div class="mt-2"><ProvenanceChip label={emailProvenance(p.sourceEmailId)} accent="violet" quiet /></div>}
                        </div>
                      )}

                      {p.type === 'payment' && (
                        <div class="border-t border-border px-4 py-3">
                          <div class="flex items-baseline justify-between gap-2">
                            <span class="text-[13px] text-ink">{p.detail}</span>
                            <span class="text-lg font-semibold text-ink">{p.amount}</span>
                          </div>
                          <p class="mt-1 text-[12px] text-muted">{p.memo}</p>
                          {p.highGate && (
                            <p class="mt-2 flex items-center gap-1.5 rounded-[8px] border border-c-amber/30 bg-c-amber/10 px-2.5 py-1.5 text-[11.5px] font-medium text-c-amber-700">
                              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z" stroke="currentColor" stroke-width="2" /></svg>
                              Consequential action — always human-gated. Nothing moves until you approve.
                            </p>
                          )}
                          {p.sourceEmailId && <div class="mt-2"><ProvenanceChip label={emailProvenance(p.sourceEmailId)} accent="amber" quiet /></div>}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>

              <!-- action row -->
              <div data-nav-actions class="flex flex-wrap items-center gap-2 border-t border-border bg-bg/40 px-4 py-3">
                <button type="button" data-nav-approve class="inline-flex items-center gap-1.5 rounded-[var(--radius-btn)] bg-primary px-4 py-2 text-[13px] font-semibold text-white transition-colors hover:bg-primary-700">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  Approve &amp; act
                </button>
                <button type="button" data-nav-edit class="rounded-[var(--radius-btn)] border border-border bg-surface px-3.5 py-2 text-[13px] font-semibold text-ink transition-colors hover:border-primary hover:text-primary">Edit draft</button>
                <button type="button" data-nav-decline class="ml-auto rounded-[var(--radius-btn)] px-3 py-2 text-[13px] font-semibold text-c-rose-700 transition-colors hover:bg-c-rose/10">Decline</button>
              </div>

              <!-- approved outcome -->
              <div data-nav-approved hidden class="border-t border-c-green/30 bg-c-green/5 px-5 py-4">
                <p class="flex items-center gap-2 text-[14px] font-semibold text-c-green-700">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  {r.onApprove.confirmation}
                </p>
                <p class="mt-2 flex items-center gap-1.5 border-t border-c-green/20 pt-2 font-mono text-[11.5px] text-muted">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="shrink-0" aria-hidden="true"><path d="M9 12l2 2 4-4M12 3l7 4v6c0 4-3 6-7 8-4-2-7-4-7-8V7l7-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  {r.onApprove.audit}
                </p>
              </div>

              <!-- declined outcome -->
              <div data-nav-declined hidden class="border-t border-border bg-bg/60 px-5 py-4">
                <p class="flex items-center gap-2 text-[14px] font-medium text-ink-2">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-muted" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                  {r.onDecline.confirmation}
                </p>
              </div>
            </figure>

            <button type="button" data-nav-reset class="mx-auto mt-3 block text-xs font-medium text-primary hover:underline" hidden>Run it again</button>
          </div>
        </div>
      ))
    }
  </div>

  <!-- takeaway -->
  <div class="mt-8 rounded-[var(--radius-card)] border border-border px-5 py-4" style="background:linear-gradient(135deg,rgba(106,92,246,.06),rgba(139,124,248,.06))">
    <p class="flex items-start gap-2.5 text-[15px] font-medium text-ink">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-primary" aria-hidden="true"><path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>
      {scene2.closingLine}
    </p>
  </div>
</section>

<script>
  const scene = document.querySelector('[data-nav-scene]');
  if (scene) {
    const responses = Array.from(scene.querySelectorAll<HTMLElement>('[data-nav-response]'));
    const empty = scene.querySelector<HTMLElement>('[data-nav-empty]');
    const fallback = scene.querySelector<HTMLElement>('[data-nav-fallback]');
    const input = scene.querySelector<HTMLInputElement>('[data-nav-input]');
    const form = scene.querySelector<HTMLFormElement>('[data-nav-form]');

    const normalize = (s: string) => s.toLowerCase().replace(/[^a-z0-9\s]/g, ' ');

    function reset(panel: HTMLElement) {
      panel.querySelector<HTMLElement>('[data-nav-actions]')!.hidden = false;
      panel.querySelector<HTMLElement>('[data-nav-approved]')!.hidden = true;
      panel.querySelector<HTMLElement>('[data-nav-declined]')!.hidden = true;
      panel.querySelector<HTMLElement>('[data-nav-reset]')!.hidden = true;
      const draft = panel.querySelector<HTMLElement>('[data-nav-draft]');
      const editor = panel.querySelector<HTMLElement>('[data-nav-editor]');
      if (draft && editor) { draft.hidden = false; editor.hidden = true; }
      const card = panel.querySelector<HTMLElement>('[data-nav-card]');
      card?.classList.remove('opacity-95');
      panel.querySelector<HTMLElement>('[data-nav-status]')?.classList.remove('!hidden');
    }

    function show(key: string) {
      responses.forEach((p) => {
        const on = p.getAttribute('data-nav-response') === key;
        p.hidden = !on;
        if (on) reset(p);
      });
      if (empty) empty.hidden = true;
      if (fallback) fallback.hidden = true;
    }

    // Chip clicks → direct target
    scene.querySelectorAll<HTMLButtonElement>('[data-nav-chip]').forEach((chip) => {
      chip.addEventListener('click', () => show(chip.getAttribute('data-nav-chip')!));
    });

    // Free-text fuzzy match
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = normalize(input?.value ?? '');
      if (!q.trim()) return;
      let best: { key: string; score: number } | null = null;
      responses.forEach((p) => {
        const tokens = (p.getAttribute('data-nav-match') ?? '').split('|');
        let score = 0;
        tokens.forEach((t) => { if (t && q.includes(normalize(t))) score += t.length; });
        if (score > 0 && (!best || score > best.score)) best = { key: p.getAttribute('data-nav-response')!, score };
      });
      if (best) show(best.key);
      else {
        responses.forEach((p) => (p.hidden = true));
        if (empty) empty.hidden = true;
        if (fallback) fallback.hidden = false;
      }
    });

    // Approve / edit / decline (event delegation)
    responses.forEach((panel) => {
      const card = panel.querySelector<HTMLElement>('[data-nav-card]');
      const actions = panel.querySelector<HTMLElement>('[data-nav-actions]');
      const approved = panel.querySelector<HTMLElement>('[data-nav-approved]');
      const declined = panel.querySelector<HTMLElement>('[data-nav-declined]');
      const again = panel.querySelector<HTMLElement>('[data-nav-reset]');
      const status = panel.querySelector<HTMLElement>('[data-nav-status]');

      panel.querySelector('[data-nav-approve]')?.addEventListener('click', () => {
        if (actions) actions.hidden = true;
        if (declined) declined.hidden = true;
        if (approved) approved.hidden = false;
        if (again) again.hidden = false;
        status?.classList.add('!hidden');
        card?.classList.add('opacity-95');
      });
      panel.querySelector('[data-nav-decline]')?.addEventListener('click', () => {
        if (actions) actions.hidden = true;
        if (approved) approved.hidden = true;
        if (declined) declined.hidden = false;
        if (again) again.hidden = false;
        status?.classList.add('!hidden');
      });
      panel.querySelector('[data-nav-edit]')?.addEventListener('click', () => {
        const draft = panel.querySelector<HTMLElement>('[data-nav-draft]');
        const editor = panel.querySelector<HTMLTextAreaElement>('[data-nav-editor]');
        if (draft && editor) {
          draft.hidden = true;
          editor.hidden = false;
          editor.focus();
        }
      });
      again?.addEventListener('click', () => reset(panel));
    });
  }
</script>
