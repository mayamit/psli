---
// Scene 1 — Communications cold-start. The flagship "whoa": on first open,
// with zero user input, PSL/i has already read the inbox and surfaces who's
// owed a reply, what Maya promised, and money buried in email — each with
// provenance, each expandable to its source + resolved facts.
import { persona, allEmails, scene1 } from '../../data/demo';
import { emailById, commitmentById, moneyById, personById, personAccent, emailProvenance, statusMeta, moneyMeta, connectionById } from '../../lib/demo';
import { accent as accentMap } from '../../lib/accents';
import ProvenanceChip from './ProvenanceChip.astro';
import SourceReveal from './SourceReveal.astro';

// Insight banner headlined on load — defaults to the AWS reframe (connection x2).
const insight = connectionById['x2'];

const columnMeta: Record<string, { dot: string; hint: string; icon: string }> = {
  replies: { dot: 'bg-primary', hint: 'Ranked by who’s waiting on you', icon: 'M4 6h16v12H4z|M4 7l8 6 8-6' },
  commitments: { dot: 'bg-c-amber', hint: 'Overdue first', icon: 'M20 6L9 17l-5-5' },
  money: { dot: 'bg-c-green', hint: 'Invoices & renewals, surfaced', icon: 'M12 3v18|M8 8h5a2.5 2.5 0 010 5H9a2.5 2.5 0 000 5h6' },
};

// Resolve each section's ids into concrete items (heterogeneous per column).
const columns = scene1.sections.map((s) => ({
  ...s,
  meta: columnMeta[s.key],
  items: s.itemIds
    .map((id) => {
      if (s.key === 'replies') return { kind: 'email' as const, email: emailById[id] };
      if (s.key === 'commitments') return { kind: 'commitment' as const, c: commitmentById[id] };
      return { kind: 'money' as const, m: moneyById[id] };
    })
    .filter((x) => x.email || x.c || x.m),
}));
---

<section aria-labelledby="scene1-title">
  <!-- Scene intro -->
  <div class="mb-6">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      {scene1.eyebrow}
    </span>
    <h2 id="scene1-title" class="mt-3 text-2xl font-semibold text-ink sm:text-[28px]">{scene1.title}</h2>
    <p class="mt-2 max-w-2xl text-[15px] text-ink-2">{scene1.sub}</p>
  </div>

  <!-- Insight banner — the "how did it know that" moment, surfaced on load -->
  {insight && (
    <div class="mb-5 overflow-hidden rounded-[var(--radius-card)] border border-primary/25 shadow-[var(--shadow-card)]" style="background:linear-gradient(135deg,rgba(106,92,246,.09),rgba(139,124,248,.05))">
      <div class="flex items-start gap-3 px-4 py-3.5 sm:px-5">
        <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-white" style="background:var(--grad)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" />
          </svg>
        </span>
        <div class="min-w-0">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-primary-700">PSL/i noticed</p>
          <p class="mt-0.5 text-[15px] font-medium text-ink">{insight.insight}</p>
          <p class="mt-1 text-[13.5px] text-ink-2">{insight.payoff}</p>
        </div>
      </div>
    </div>
  )}

  <!-- The product surface -->
  <div class="overflow-hidden rounded-[var(--radius-card)] border border-border bg-bg shadow-[var(--shadow-lift)]">
    <!-- surface toolbar -->
    <div class="flex flex-wrap items-center justify-between gap-2 border-b border-border bg-surface px-4 py-3 sm:px-5">
      <div class="flex items-center gap-2.5">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg text-white" style="background:var(--grad)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16v12H4z" stroke="currentColor" stroke-width="2" /><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="2" />
          </svg>
        </span>
        <div class="leading-tight">
          <p class="text-sm font-semibold text-ink">Today · {persona.today}</p>
          <p class="text-[11.5px] text-muted">Resolved from {allEmails.length} emails · you set up nothing</p>
        </div>
      </div>
      <span class="hidden items-center gap-1.5 rounded-full border border-c-green/30 bg-c-green/10 px-2.5 py-1 text-[11px] font-semibold text-c-green-700 sm:inline-flex">
        <span class="h-1.5 w-1.5 rounded-full bg-c-green"></span>
        Inbox read · 0 actions taken
      </span>
    </div>

    <!-- three-column briefing -->
    <div class="grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3">
      {
        columns.map((col) => (
          <div class="bg-bg p-3 sm:p-4">
            <div class="mb-3 flex items-baseline justify-between gap-2 px-1">
              <p class="flex items-center gap-2 text-sm font-semibold text-ink">
                <span class={`h-2 w-2 rounded-full ${col.meta.dot}`} />
                {col.label}
                <span class="text-xs font-medium text-muted">{col.items.length}</span>
              </p>
              <span class="text-[11px] text-muted">{col.meta.hint}</span>
            </div>

            <div class="flex flex-col gap-2">
              {col.items.map((it, i) => {
                // Common fields resolved per row kind
                const email = it.kind === 'email' ? it.email : null;
                const c = it.kind === 'commitment' ? it.c : null;
                const m = it.kind === 'money' ? it.m : null;
                const personId = email?.from ?? c?.personId ?? m!.personId;
                const person = personById[personId];
                const a = accentMap[personAccent(personId)];
                const sourceEmailId = email?.id ?? c?.sourceEmailId ?? m!.sourceEmailId;

                const primary = email ? person?.name : c ? c.text : m!.label;
                const secondary = email
                  ? email.subject
                  : c
                    ? `to ${person?.name} · due ${c.due}`
                    : person?.name + (m!.note ? ` · ${m!.note}` : '');

                return (
                  <details class="group rounded-[var(--radius-card)] border border-border bg-surface open:border-primary/30 open:shadow-[var(--shadow-card)]">
                    <summary class="flex cursor-pointer list-none items-start gap-3 px-3.5 py-3 [&::-webkit-details-marker]:hidden">
                      <span class={`mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] text-xs font-semibold ${a.softBg} ${a.text}`}>
                        {person?.initials ?? '—'}
                      </span>

                      <span class="flex min-w-0 flex-1 flex-col">
                        <span class="flex items-start justify-between gap-2">
                          <span class="flex min-w-0 flex-col">
                            <span class="truncate text-[14px] font-semibold text-ink">{primary}</span>
                            <span class="mt-0.5 truncate text-[12.5px] text-muted">{secondary}</span>
                          </span>

                          <span class="flex shrink-0 items-center gap-1.5">
                            {c && (
                              <span class={`rounded-full px-2 py-0.5 text-[10.5px] font-semibold ${accentMap[statusMeta[c.status].accent].text} ${accentMap[statusMeta[c.status].accent].softBg}`}>
                                {statusMeta[c.status].label}
                              </span>
                            )}
                            {m && <span class="text-[13px] font-semibold text-ink">{m.amount}</span>}
                            {email && <span class="text-[11px] font-medium text-muted">{email.date}</span>}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-muted transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
                              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                        </span>

                        <span class="mt-1.5 flex">
                          <ProvenanceChip label={emailProvenance(sourceEmailId)} accent={personAccent(personId)} />
                        </span>
                      </span>
                    </summary>

                    <SourceReveal emailId={sourceEmailId} />
                  </details>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>

    <!-- closing takeaway -->
    <div class="border-t border-border px-4 py-4 sm:px-5" style="background:linear-gradient(135deg,rgba(106,92,246,.06),rgba(139,124,248,.06))">
      <p class="flex items-center gap-2.5 text-[15px] font-medium text-ink">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0 text-primary" aria-hidden="true">
          <path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
        </svg>
        {scene1.closingLine}
      </p>
    </div>
  </div>

  <p class="mt-3 text-center text-xs text-muted">Every line traces to its source. Open any item to see the email it came from — and what PSL/i resolved out of it.</p>
</section>
