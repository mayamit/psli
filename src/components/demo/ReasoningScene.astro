---
// Scene 3 — Reasoning over your own life. Chips + fuzzy-matched free text
// return a structured answer assembled from the Foundation, each with
// citations back into people / docs / emails. The moat: a blank-window
// chatbot can't answer these. All scripted.
import { scene3, scene3ExtraResponses, persona } from '../../data/demo';
import type { Accent } from '../../lib/accents';
import ProvenanceChip from './ProvenanceChip.astro';

// Merge the expansion pack (no schema change). Feature "What's blocking the
// partner meeting?" first by inserting its key before the base responses.
const featuredKey = 'blocking-partner-meeting';
const responseMap: Record<string, any> = {
  [featuredKey]: scene3ExtraResponses[featuredKey],
  ...scene3.responses,
  ...scene3ExtraResponses,
};
const responses = Object.entries(responseMap);

// --- tiny markdown-lite: **bold** + "• " bullet lines + paragraphs ----------
function renderInline(text: string): { t: string; b: boolean }[] {
  return text
    .split('**')
    .map((s, i) => ({ t: s, b: i % 2 === 1 }))
    .filter((p) => p.t.length > 0);
}
type Block =
  | { type: 'p'; text: string }
  | { type: 'ul'; items: string[] }
  | { type: 'ol'; items: { n: string; text: string }[] };
function parseAnswer(answer: string): Block[] {
  const blocks: Block[] = [];
  let ul: string[] | null = null;
  let ol: { n: string; text: string }[] | null = null;
  const flush = () => {
    if (ul) { blocks.push({ type: 'ul', items: ul }); ul = null; }
    if (ol) { blocks.push({ type: 'ol', items: ol }); ol = null; }
  };
  for (const raw of answer.split('\n')) {
    const line = raw.trim();
    const om = line.match(/^(\d+)\.\s+(.*)$/);
    if (line === '') {
      flush();
    } else if (line.startsWith('•')) {
      if (ol) { blocks.push({ type: 'ol', items: ol }); ol = null; }
      (ul ??= []).push(line.replace(/^•\s*/, ''));
    } else if (om) {
      if (ul) { blocks.push({ type: 'ul', items: ul }); ul = null; }
      (ol ??= []).push({ n: om[1], text: om[2] });
    } else {
      flush();
      blocks.push({ type: 'p', text: line });
    }
  }
  flush();
  return blocks;
}

// Accent per citation source type — supports every shape the expansion uses.
function citationAccent(c: any): Accent {
  if (c.emailId || c.emailIds) return 'blue';
  if (c.docId || c.docIds) return 'violet';
  if (c.moneyId || c.moneyIds) return 'amber';
  if (c.commitmentId || c.commitmentIds) return 'teal';
  if (c.lifeId || c.lifeIds) return 'rose';
  if (c.connectionId || c.connectionIds) return 'green';
  return 'violet';
}
---

<section aria-labelledby="scene3-title" data-reason-scene>
  <!-- Scene intro -->
  <div class="mb-6">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      {scene3.eyebrow}
    </span>
    <h2 id="scene3-title" class="mt-3 text-2xl font-semibold text-ink sm:text-[28px]">{scene3.title}</h2>
  </div>

  <!-- Prompt box -->
  <div class="rounded-[var(--radius-card)] border border-border bg-surface p-4 shadow-[var(--shadow-card)]">
    <p class="mb-2.5 text-xs font-semibold uppercase tracking-wide text-muted">Ask over Maya's life</p>
    <div class="flex flex-wrap gap-2">
      {
        responses.map(([key, r]) => (
          <button
            type="button"
            data-reason-chip={key}
            class:list={[
              'rounded-full border px-3.5 py-1.5 text-[13px] font-medium transition-colors focus-visible:outline-2',
              key === featuredKey
                ? 'border-primary bg-primary-50 text-primary-700 hover:bg-primary-50'
                : 'border-border bg-bg text-ink-2 hover:border-primary hover:text-primary',
            ]}
          >
            {key === featuredKey && (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="mr-1 inline-block align-[-1px]" aria-hidden="true"><path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" /></svg>
            )}
            {r.question}
          </button>
        ))
      }
    </div>
    <form data-reason-form class="mt-3 flex gap-2" novalidate>
      <input
        type="text"
        data-reason-input
        autocomplete="off"
        placeholder="…or ask your own — e.g. “what do I owe Jane?”"
        aria-label="Ask a question over Maya's life"
        class="min-w-0 flex-1 rounded-[var(--radius-btn)] border border-border bg-bg px-3.5 py-2.5 text-[14px] text-ink placeholder:text-muted focus-visible:outline-2"
      />
      <button type="submit" class="shrink-0 rounded-[var(--radius-btn)] bg-primary px-4 py-2.5 text-[14px] font-semibold text-white transition-colors hover:bg-primary-700">
        Ask
      </button>
    </form>
    <p data-reason-fallback hidden class="mt-2.5 flex items-start gap-2 rounded-[10px] border border-c-amber/30 bg-c-amber/10 px-3 py-2 text-[13px] text-ink-2">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-c-amber-700" aria-hidden="true">
        <path d="M12 9v4m0 4h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L14.7 3.9a2 2 0 00-3.4 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>{scene3.fallback}</span>
    </p>
  </div>

  <!-- Results -->
  <div class="mt-6">
    <p data-reason-empty class="rounded-[var(--radius-card)] border border-dashed border-border bg-surface/60 px-6 py-14 text-center text-sm text-muted">
      Pick a question above. The answer is assembled from Maya's Foundation — and every claim is traced.
    </p>

    {
      responses.map(([key, r]) => (
        <div data-reason-response={key} data-reason-match={r.matches.join('|')} hidden>
          <div class="mx-auto max-w-2xl">
            <!-- the question -->
            <div class="mb-3 flex items-center justify-end gap-2.5">
              <p class="rounded-[var(--radius-card)] rounded-br-sm bg-primary px-4 py-2.5 text-[14px] font-medium text-white">{r.question}</p>
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-c-violet/10 text-xs font-semibold text-c-violet-700">MC</span>
            </div>

            <!-- the answer -->
            <div class="overflow-hidden rounded-[var(--radius-card)] border border-border bg-surface shadow-[var(--shadow-card)]">
              <div class="flex items-center gap-2.5 border-b border-border px-5 py-3">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg text-white" style="background:var(--grad)">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" />
                  </svg>
                </span>
                <div class="leading-tight">
                  <p class="text-sm font-semibold text-ink">{persona.name}'s PSL/i</p>
                  <p class="text-[11.5px] text-muted">Assembled from your Foundation · {r.citations.length} sources</p>
                </div>
              </div>

              <div class="space-y-3 px-5 py-4 text-[14.5px] leading-relaxed text-ink-2">
                {parseAnswer(r.answer).map((block) => (
                  <>
                    {block.type === 'p' && (
                      <p>{renderInline(block.text).map((s) => (s.b ? <strong class="font-semibold text-ink">{s.t}</strong> : s.t))}</p>
                    )}
                    {block.type === 'ul' && (
                      <ul class="space-y-1.5">
                        {block.items.map((item) => (
                          <li class="flex gap-2">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary/50" />
                            <span>{renderInline(item).map((s) => (s.b ? <strong class="font-semibold text-ink">{s.t}</strong> : s.t))}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                    {block.type === 'ol' && (
                      <ol class="space-y-1.5">
                        {block.items.map((item) => (
                          <li class="flex gap-2.5">
                            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary-50 text-[11px] font-semibold text-primary-700">{item.n}</span>
                            <span>{renderInline(item.text).map((s) => (s.b ? <strong class="font-semibold text-ink">{s.t}</strong> : s.t))}</span>
                          </li>
                        ))}
                      </ol>
                    )}
                  </>
                ))}
              </div>

              <!-- citations -->
              <div class="border-t border-border bg-bg/50 px-5 py-3.5">
                <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-muted">Traced to</p>
                <div class="flex flex-wrap gap-2">
                  {r.citations.map((c: any) => (
                    <ProvenanceChip label={c.label} accent={citationAccent(c)} />
                  ))}
                </div>
              </div>

              {'followUp' in r && (r as any).followUp && (
                <div class="border-t border-border px-5 py-3">
                  <button type="button" data-reason-followup class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-primary hover:underline">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    {(r as any).followUp}
                  </button>
                </div>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- contrast callout -->
  <div class="mt-8 rounded-[var(--radius-card)] border border-border px-5 py-4" style="background:linear-gradient(135deg,rgba(106,92,246,.06),rgba(139,124,248,.06))">
    <p class="flex items-start gap-2.5 text-[15px] font-medium text-ink">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-primary" aria-hidden="true"><path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>
      {scene3.contrastLine}
    </p>
  </div>
</section>

<script>
  const scene = document.querySelector('[data-reason-scene]');
  if (scene) {
    const responses = Array.from(scene.querySelectorAll<HTMLElement>('[data-reason-response]'));
    const empty = scene.querySelector<HTMLElement>('[data-reason-empty]');
    const fallback = scene.querySelector<HTMLElement>('[data-reason-fallback]');
    const input = scene.querySelector<HTMLInputElement>('[data-reason-input]');
    const form = scene.querySelector<HTMLFormElement>('[data-reason-form]');

    const normalize = (s: string) => s.toLowerCase().replace(/[^a-z0-9\s]/g, ' ');

    function show(key: string) {
      responses.forEach((p) => (p.hidden = p.getAttribute('data-reason-response') !== key));
      if (empty) empty.hidden = true;
      if (fallback) fallback.hidden = true;
    }

    scene.querySelectorAll<HTMLButtonElement>('[data-reason-chip]').forEach((chip) => {
      chip.addEventListener('click', () => show(chip.getAttribute('data-reason-chip')!));
    });

    // Cross-lens routing: the Full-picture surface asks us to reveal a specific
    // answer by key (dispatched after DemoShell switches to this panel).
    document.addEventListener('demo:goto-reason', (e) => {
      const key = (e as CustomEvent).detail?.key;
      const target = key && responses.find((p) => p.getAttribute('data-reason-response') === key);
      if (target) {
        show(key);
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = normalize(input?.value ?? '');
      if (!q.trim()) return;
      let best: { key: string; score: number } | null = null;
      responses.forEach((p) => {
        const tokens = (p.getAttribute('data-reason-match') ?? '').split('|');
        let score = 0;
        tokens.forEach((t) => { if (t && q.includes(normalize(t))) score += t.length; });
        if (score > 0 && (!best || score > best.score)) best = { key: p.getAttribute('data-reason-response')!, score };
      });
      if (best) show(best.key);
      else {
        responses.forEach((p) => (p.hidden = true));
        if (empty) empty.hidden = true;
        if (fallback) fallback.hidden = false;
      }
    });

    // Follow-up ("Want me to send it?") jumps to the Navigator scene.
    scene.querySelectorAll('[data-reason-followup]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const navTab = document.querySelector<HTMLButtonElement>('[data-scene="2"]');
        navTab?.click();
        navTab?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }
</script>
