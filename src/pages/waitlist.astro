---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';

// Wire to a form service (Formspree/Tally/etc.) via env var — never commit a
// secret. Falls back to a harmless placeholder so the demo renders.
const endpoint = import.meta.env.PUBLIC_WAITLIST_ENDPOINT || '#';
const configured = endpoint !== '#';

const perks = [
  'Priority onboarding for Cloud or Home Server',
  'Direct line to the team building Sable',
  'Locked-in early-access pricing',
];
---

<Base
  title="Get early access"
  path="/waitlist"
  description="Join the Sable early-access waitlist. Priority onboarding, a direct line to the team, and locked-in pricing."
>
  <PageHeader
    eyebrow="Get early access"
    title="Be among the first to be truly known."
    subhead="Sable is rolling out to early users now. Join the waitlist and we’ll be in touch."
  />

  <section class="py-20 sm:py-24">
    <div class="mx-auto grid max-w-5xl gap-12 px-5 sm:px-8 lg:grid-cols-[1fr_1fr]">
      <div>
        <h2 class="text-2xl font-bold text-ink">What early access gets you</h2>
        <ul class="mt-6 space-y-4">
          {
            perks.map((p) => (
              <li class="flex items-start gap-3 text-[15px] text-ink">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {p}
              </li>
            ))
          }
        </ul>
        <p class="mt-8 text-sm text-muted">Your data stays yours. We’ll only use your email to contact you about early access.</p>
      </div>

      <div class="rounded-[var(--radius-card)] border border-border bg-surface p-7 shadow-[var(--shadow-card)]">
        <form
          method="POST"
          action={endpoint}
          class="flex flex-col gap-4"
        >
          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="rounded-[var(--radius-btn)] border border-border bg-bg px-4 py-2.5 text-[15px] text-ink outline-none focus:border-primary"
            />
          </label>
          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="rounded-[var(--radius-btn)] border border-border bg-bg px-4 py-2.5 text-[15px] text-ink outline-none focus:border-primary"
            />
          </label>
          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-ink">Which tier interests you?</span>
            <select
              name="tier"
              class="rounded-[var(--radius-btn)] border border-border bg-bg px-4 py-2.5 text-[15px] text-ink outline-none focus:border-primary"
            >
              <option>Cloud</option>
              <option>Home Server</option>
              <option>Not sure yet</option>
            </select>
          </label>
          <button
            type="submit"
            class="mt-1 rounded-[var(--radius-btn)] bg-primary px-5 py-3 text-[15px] font-semibold text-white transition-colors hover:bg-primary-700"
          >
            Request early access
          </button>
          {
            !configured && (
              <p class="text-xs text-muted">
                Demo form — connect a form service via <code>PUBLIC_WAITLIST_ENDPOINT</code> to collect submissions.
              </p>
            )
          }
        </form>
      </div>
    </div>
  </section>
</Base>
