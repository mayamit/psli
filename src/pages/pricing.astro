---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import Pricing from '../components/home/Pricing.astro';
import FAQ from '../components/home/FAQ.astro';
import FinalCta from '../components/home/FinalCta.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Personal Semantic Layer (PSL/i)',
  description:
    'One price — $100/month. Cloud or Home Server. All four V1 lenses, Navigator, and your private Foundation included.',
  brand: { '@type': 'Brand', name: 'PSL/i' },
  offers: {
    '@type': 'Offer',
    price: '100',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '100',
      priceCurrency: 'USD',
      unitText: 'MONTH',
    },
  },
};
---

<Base
  title="Pricing"
  path="/pricing"
  description="One price — $100/month. Two tiers, Cloud or Home Server. Everything included, no feature tiers to decode."
  jsonLd={jsonLd}
>
  <PageHeader
    eyebrow="Pricing"
    title="One price. Everything included."
    subhead="Choose where PSL/i runs — Cloud or Home Server. The product is the same, and so is the price."
  />
  <Pricing />
  <FAQ />
  <FinalCta />
</Base>
