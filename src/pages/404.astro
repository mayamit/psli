---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
---

<Base title="Page not found" path="/404">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-5 py-32 text-center sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-wider text-primary">404</p>
    <h1 class="mt-3 text-4xl font-bold sm:text-5xl">This page slipped our memory.</h1>
    <p class="mt-4 text-lg text-ink-2">
      The page you’re after doesn’t exist — but PSL/i never forgets the important things.
    </p>
    <div class="mt-8">
      <Button href="/" variant="primary">Back to home</Button>
    </div>
  </section>
</Base>
