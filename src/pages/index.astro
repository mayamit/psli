---
import Base from '../layouts/Base.astro';
import Hero from '../components/home/Hero.astro';
import Problem from '../components/home/Problem.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import Lenses from '../components/home/Lenses.astro';
import WorksOverApps from '../components/home/WorksOverApps.astro';
import Trust from '../components/home/Trust.astro';
import DataPlace from '../components/home/DataPlace.astro';
import Credibility from '../components/home/Credibility.astro';
import Pricing from '../components/home/Pricing.astro';
import FAQ from '../components/home/FAQ.astro';
import FinalCta from '../components/home/FinalCta.astro';
import { site } from '../data/site';
import { href } from '../lib/url';

const siteUrl = new URL(href('/'), Astro.site).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'PSL',
    url: siteUrl,
    brand: { '@type': 'Brand', name: 'PSL/i' },
    description: site.description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Personal Semantic Layer (PSL/i)',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Cloud, Home Server',
    description: site.description,
    offers: {
      '@type': 'Offer',
      price: '100',
      priceCurrency: 'USD',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '100',
        priceCurrency: 'USD',
        unitText: 'MONTH',
      },
    },
  },
];
---

<Base path="/" jsonLd={jsonLd}>
  <Hero />
  <Problem />
  <HowItWorks />
  <Lenses />
  <WorksOverApps />
  <Trust />
  <DataPlace />
  <Credibility />
  <Pricing />
  <FAQ />
  <FinalCta />
</Base>
